# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/fotobox_booking

# ==========================================
# Shopify Configuration
# ==========================================
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-admin-api-access-token
SHOPIFY_API_KEY=your-api-key
SHOPIFY_API_SECRET=your-api-secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
SHOPIFY_HOST_NAME=localhost:3000

# Shopify Product Sync Interval (in hours)
# Wie oft Produktdaten (Titel, Preise) von Shopify synchronisiert werden
# WICHTIG: Inventar-Anzahlen werden NICHT synchronisiert (nur lokal verwaltet)
SHOPIFY_SYNC_INTERVAL_HOURS=6

# ==========================================
# Authentication
# ==========================================
JWT_SECRET=your-jwt-secret-min-32-chars

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==========================================
# Booking Configuration
# ==========================================

# Soft Lock Duration (in minutes)
# Wie lange PENDING-Buchungen im Kalender blockiert werden
SOFT_LOCK_MINUTES=30

# Pending Timeout (in hours)
# Nach wie vielen Stunden PENDING-Buchungen automatisch geloescht werden
PENDING_TIMEOUT_HOURS=0.5

# Minimum Lead Time (in days)
# Mindestvorlaufzeit fuer Buchungen
MIN_LEAD_TIME_DAYS=4

# Shipping Buffer Before (in days)
# Puffer vor dem Event-Tag (fuer Versand)
SHIPPING_BUFFER_BEFORE=2

# Shipping Buffer After (in days)
# Puffer nach dem Event-Tag (fuer Rueckversand)
SHIPPING_BUFFER_AFTER=2

# Critical Days Threshold
# Anzahl der Tage vor dem Event, ab denen eine Buchung als "kritisch" markiert wird
CRITICAL_DAYS_THRESHOLD=3

# ==========================================
# Email Configuration (SMTP)
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM=noreply@yourstore.com
ADMIN_EMAIL=admin@yourstore.com

# ==========================================
# DHL Shipping (Optional)
# ==========================================
DHL_API_KEY=your-dhl-api-key
DHL_API_SECRET=your-dhl-api-secret
DHL_ACCOUNT_NUMBER=your-dhl-account-number

# ==========================================
# Server Configuration
# ==========================================
PORT=3000
NODE_ENV=development

# CORS: Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Calendar feed secret token
CALENDAR_SECRET=your-calendar-feed-secret

# Shop URL (for links in emails)
SHOP_URL=https://your-store.myshopify.com
